<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.T1_primera_pregunta">
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity android:name=".Views.MenuAdminActivity" android:exported="false"/>
        <activity android:name=".Views.MenuElectorActivity" android:exported="false"/>

        <activity android:name=".Views.ListaCandidatosActivity" android:exported="false"/>
        <activity android:name=".Views.FormCandidatoActivity" android:exported="false"/>

        <activity android:name=".Views.ListaElectoresActivity" android:exported="false"/>
        <activity android:name=".Views.FormElectorActivity" android:exported="false"/>

        <activity android:name=".Views.EleccionConfigActivity" android:exported="false"/>
        <activity android:name=".Views.VotarActivity" android:exported="false"/>
        <activity android:name=".Views.ResultadosActivity" android:exported="false"/>
    </application>

</manifest>